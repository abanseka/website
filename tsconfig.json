{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["./components/*"],
      "@styles/*": ["./styles/components/*"],
      "@assets/*": ["./assets/*"],
      "types/*": ["./types/*"],
      "utils/*": ["./utils/*"],
      "theme": ["./theme.ts"],
      "contentlayer/generated": ["./.contentlayer/generated"]
    }
    "target": "es5,es2015,es2016,es2017,es2018,es2019,es2020,es2021",
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".contentlayer/generated"
  ],
  "exclude": ["node_modules"]
}
